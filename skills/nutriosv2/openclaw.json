{
  "name": "nutriosv2",
  "version": "1.0.0",
  "description": "NutriOS - conversational food and protocol companion",
  "tools": [
    {
      "name": "turn_state",
      "description": "Call first on every user turn. Classifies intent, detects intent-transition boundary, resets session JSONL on boundary, and returns the routed capability prompt read fresh from disk. Returns {intent, ambiguous, boundary, capability_prompt, today_date}.",
      "command": "python3 /Users/ranbirchawla/.openclaw/workspace/skills/nutriosv2/scripts/turn_state.py",
      "inputSchema": {
        "type": "object",
        "properties": {
          "user_message": {
            "type": "string",
            "description": "The user's message text verbatim"
          },
          "user_id": {
            "type": "integer",
            "description": "Telegram user ID"
          },
          "intent_override": {
            "type": "string",
            "enum": [
              "mesocycle_setup",
              "cycle_read_back",
              "today_view",
              "meal_log",
              "default"
            ],
            "description": "When present, skips intent classification and routes directly to this intent. Use for slash command dispatch (/newcycle, /today, /log, /cycle, /clonecycle)."
          }
        },
        "required": [
          "user_message",
          "user_id"
        ]
      }
    },
    {
      "name": "compute_candidate_macros",
      "description": "Pure macro math from intent constraints. Returns {weekly_deficit_kcal, daily_deficit_kcal, calories, protein_g, fat_g, carbs_g} \u2014 macro fields may be null if corresponding input is missing; deficit fields are null when target_deficit_kcal is not provided.",
      "command": "python3 /Users/ranbirchawla/.openclaw/workspace/skills/nutriosv2/scripts/compute_candidate_macros.py",
      "inputSchema": {
        "type": "object",
        "properties": {
          "target_deficit_kcal": {
            "type": "integer",
            "description": "Deficit value in the unit specified by deficit_unit"
          },
          "deficit_unit": {
            "type": "string",
            "enum": [
              "weekly_kcal",
              "daily_kcal"
            ],
            "description": "Unit of target_deficit_kcal. 'weekly_kcal' (default) or 'daily_kcal'. Tool converts daily to weekly automatically."
          },
          "protein_floor_g": {
            "type": "integer",
            "description": "Minimum daily protein in grams"
          },
          "fat_ceiling_g": {
            "type": "integer",
            "description": "Maximum daily fat in grams"
          },
          "estimated_tdee_kcal": {
            "type": "integer",
            "description": "Estimated total daily energy expenditure in kcal"
          }
        }
      }
    },
    {
      "name": "lock_mesocycle",
      "description": "End any active mesocycle and lock a new one. Returns {mesocycle_id}.",
      "command": "python3 /Users/ranbirchawla/.openclaw/workspace/skills/nutriosv2/scripts/lock_mesocycle.py",
      "inputSchema": {
        "type": "object",
        "properties": {
          "user_id": {
            "type": "integer",
            "description": "Telegram user ID"
          },
          "name": {
            "type": "string",
            "description": "Cycle name, e.g. 'cut'"
          },
          "weeks": {
            "type": "integer",
            "description": "Duration in weeks (>= 1)"
          },
          "start_date": {
            "type": "string",
            "description": "ISO date, set by Python to today"
          },
          "dose_weekday": {
            "type": "integer",
            "description": "0=Mon .. 6=Sun"
          },
          "macro_table": {
            "type": "array",
            "description": "Exactly 7 rows for the 7-day plan. First row is the dose day; each subsequent row is one day later.",
            "items": {
              "type": "object",
              "properties": {
                "calories": {
                  "type": "integer"
                },
                "protein_g": {
                  "type": "integer"
                },
                "fat_g": {
                  "type": "integer"
                },
                "carbs_g": {
                  "type": "integer"
                },
                "restrictions": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "required": [
                "calories",
                "protein_g",
                "fat_g",
                "carbs_g",
                "restrictions"
              ]
            }
          },
          "intent": {
            "type": "object",
            "properties": {
              "target_deficit_kcal": {
                "type": "integer"
              },
              "protein_floor_g": {
                "type": "integer"
              },
              "fat_ceiling_g": {
                "type": "integer"
              },
              "rationale": {
                "type": "string"
              }
            }
          }
        },
        "required": [
          "user_id",
          "name",
          "weeks",
          "start_date",
          "dose_weekday",
          "macro_table",
          "intent"
        ]
      }
    },
    {
      "name": "get_active_mesocycle",
      "description": "Return the current active mesocycle for this user, or null if none.",
      "command": "python3 /Users/ranbirchawla/.openclaw/workspace/skills/nutriosv2/scripts/get_active_mesocycle.py",
      "inputSchema": {
        "type": "object",
        "properties": {
          "user_id": {
            "type": "integer",
            "description": "Telegram user ID"
          }
        },
        "required": [
          "user_id"
        ]
      }
    },
    {
      "name": "recompute_macros_with_overrides",
      "description": "Redistribute a weekly kcal budget across 7 days given per-day calorie overrides. Call when the user proposes changing a specific day's calories during table negotiation. Returns {weekly_kcal_target, rows} ; 7 MacroRow objects with the redistributed values.",
      "command": "python3 /Users/ranbirchawla/.openclaw/workspace/skills/nutriosv2/scripts/recompute_macros_with_overrides.py",
      "inputSchema": {
        "type": "object",
        "properties": {
          "estimated_tdee_kcal": {
            "type": "integer",
            "description": "User's estimated total daily energy expenditure"
          },
          "target_deficit_kcal": {
            "type": "integer",
            "description": "Weekly deficit in kcal (pass through verbatim from user)"
          },
          "dose_weekday": {
            "type": "integer",
            "description": "0=Mon..6=Sun ; the dose day for this cycle"
          },
          "protein_floor_g": {
            "type": "integer",
            "description": "Minimum daily protein in grams"
          },
          "fat_ceiling_g": {
            "type": "integer",
            "description": "Maximum daily fat in grams"
          },
          "overrides": {
            "type": "object",
            "description": "Map of plan-position string key ('0'..'6') to row override values. Each entry has calories (required), protein_g and fat_g (optional)."
          }
        },
        "required": [
          "estimated_tdee_kcal",
          "target_deficit_kcal",
          "dose_weekday",
          "protein_floor_g",
          "fat_ceiling_g",
          "overrides"
        ]
      }
    },
    {
      "name": "estimate_macros_from_description",
      "description": "Estimate macros for a food item from a natural-language description. Returns {calories: int, protein_g: float, fat_g: float, carbs_g: float, confidence: 'high'|'medium'|'low'}. Call once per food item; do not call again for the same item.",
      "command": "python3 /Users/ranbirchawla/.openclaw/workspace/skills/nutriosv2/scripts/estimate_macros.py",
      "inputSchema": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string",
            "description": "Natural-language food description, verbatim from the user"
          }
        },
        "required": [
          "description"
        ]
      }
    },
    {
      "name": "get_daily_reconciled_view",
      "description": "Return reconciled daily intake vs. mesocycle target for a user. Returns {target, consumed, remaining, is_expired, entries}. remaining is {calories, protein_g, fat_g, carbs_g} as integers (target minus consumed); null when no active cycle.",
      "command": "python3 /Users/ranbirchawla/.openclaw/workspace/skills/nutriosv2/scripts/get_daily_reconciled_view.py",
      "inputSchema": {
        "type": "object",
        "properties": {
          "user_id": {
            "type": "integer",
            "description": "Telegram user ID"
          },
          "date": {
            "type": "string",
            "description": "ISO date (YYYY-MM-DD) in the user's local timezone"
          },
          "active_timezone": {
            "type": "string",
            "description": "User's IANA timezone, e.g. 'America/Denver'"
          }
        },
        "required": [
          "user_id",
          "date",
          "active_timezone"
        ]
      }
    },
    {
      "name": "write_meal_log",
      "description": "Append a meal log entry for a user. Returns {log_id}.",
      "command": "python3 /Users/ranbirchawla/.openclaw/workspace/skills/nutriosv2/scripts/write_meal_log.py",
      "inputSchema": {
        "type": "object",
        "properties": {
          "user_id": {
            "type": "integer",
            "description": "Telegram user ID"
          },
          "food_description": {
            "type": "string",
            "description": "What the user ate, in their words"
          },
          "macros": {
            "type": "object",
            "description": "Macro breakdown for this meal",
            "properties": {
              "calories": {
                "type": "integer"
              },
              "protein_g": {
                "type": "integer"
              },
              "fat_g": {
                "type": "integer"
              },
              "carbs_g": {
                "type": "integer"
              }
            },
            "required": [
              "calories",
              "protein_g",
              "fat_g",
              "carbs_g"
            ]
          },
          "source": {
            "type": "string",
            "description": "Always 'ad_hoc' for user-described meals"
          },
          "recipe_id": {
            "type": "string",
            "description": "Pass null for ad_hoc meals"
          },
          "recipe_name_snapshot": {
            "type": "string",
            "description": "Pass null for ad_hoc meals"
          },
          "supersedes_log_id": {
            "type": "string",
            "description": "Pass null unless correcting a previous log entry"
          },
          "active_timezone": {
            "type": "string",
            "description": "User's IANA timezone, e.g. 'America/Denver'"
          }
        },
        "required": [
          "user_id",
          "food_description",
          "macros",
          "source",
          "recipe_id",
          "recipe_name_snapshot",
          "supersedes_log_id",
          "active_timezone"
        ]
      }
    }
  ]
}